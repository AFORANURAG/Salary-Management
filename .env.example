# Database (PostgreSQL 16)
DB_HOST=localhost
DB_PORT=5432
DB_USER=salary
DB_PASSWORD=salary
DB_NAME=salary_mgmt
DB_LOGGING=false

# API (NestJS)
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Auth (JWT + bcrypt)
JWT_SECRET=change-me-in-production
JWT_EXPIRY=8h
BCRYPT_ROUNDS=12
FRONTEND_URL=http://localhost:3000

# Seed admin (created by pnpm --filter api seed)
SEED_ADMIN_EMAIL=admin@acme.com
SEED_ADMIN_PASSWORD=change-me-in-production

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
